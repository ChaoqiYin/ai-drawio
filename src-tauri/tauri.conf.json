{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI Drawio",
  "mainBinaryName": "ai-drawio",
  "version": "0.1.0",
  "identifier": "com.example.ai-drawio",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:3001",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Drawio",
        "url": "index.html",
        "width": 1440,
        "height": 900,
        "visible": false,
        "resizable": true
      },
      {
        "label": "splash",
        "title": "AI Drawio \u6b63\u5728\u542f\u52a8",
        "url": "splash.html",
        "width": 420,
        "height": 280,
        "visible": false,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "../assets/ai-drawio.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "./resources/macos/install-cli-to-path.sh": "macos/install-cli-to-path.sh"
    },
    "macOS": {
      "files": {
        "SharedSupport/cli-completions/_ai-drawio": "./target/cli-completions/_ai-drawio",
        "SharedSupport/cli-completions/ai-drawio.bash": "./target/cli-completions/ai-drawio.bash",
        "SharedSupport/cli-completions/ai-drawio.fish": "./target/cli-completions/ai-drawio.fish"
      }
    }
  },
  "plugins": {
    "cli": {
      "description": "AI Drawio packaged desktop command line interface",
      "subcommands": {
        "open": {
          "description": "Launch the desktop app",
          "args": [
            {
              "name": "mode",
              "takesValue": true,
              "required": false
            }
          ]
        },
        "status": {
          "description": "Inspect the running desktop shell state"
        },
        "conversation": {
          "description": "Manage local conversations",
          "subcommands": {
            "create": {
              "description": "Create a new local conversation"
            }
          }
        },
        "session": {
          "description": "Inspect or open local sessions",
          "subcommands": {
            "create": {
              "description": "Create a new local session and wait until it is ready"
            },
            "list": {
              "description": "List all local sessions"
            },
            "open": {
              "description": "Open a local session",
              "args": [
                {
                  "name": "session-id",
                  "index": 1,
                  "required": true
                }
              ]
            }
          }
        },
        "canvas": {
          "description": "Read or write the current draw.io document",
          "subcommands": {
            "document.get": {
              "description": "Read the current draw.io document",
              "args": [
                {
                  "name": "session-id",
                  "index": 1,
                  "required": true
                },
                {
                  "name": "output-file",
                  "takesValue": true,
                  "required": false
                }
              ]
            },
            "document.svg": {
              "description": "Export the current draw.io document as per-page SVG",
              "args": [
                {
                  "name": "session-id",
                  "index": 1,
                  "required": true
                },
                {
                  "name": "output-file",
                  "takesValue": true,
                  "required": false
                }
              ]
            },
            "document.preview": {
              "description": "Export the current draw.io document as per-page PNG preview images",
              "args": [
                {
                  "name": "session-id",
                  "index": 1,
                  "required": true
                },
                {
                  "name": "output-directory",
                  "index": 2,
                  "required": true
                },
                {
                  "name": "page",
                  "takesValue": true,
                  "required": false
                }
              ]
            },
            "document.apply": {
              "description": "Apply a draw.io document to the specified session",
              "args": [
                {
                  "name": "session-id",
                  "index": 1,
                  "required": true
                },
                {
                  "name": "prompt",
                  "index": 2,
                  "required": true
                },
                {
                  "name": "xml",
                  "index": 3,
                  "required": false
                },
                {
                  "name": "xml-file",
                  "takesValue": true,
                  "required": false
                },
                {
                  "name": "xml-stdin",
                  "takesValue": false,
                  "required": false
                },
                {
                  "name": "base-version",
                  "takesValue": true,
                  "required": false
                },
                {
                  "name": "output-file",
                  "takesValue": true,
                  "required": false
                }
              ]
            },
            "document.restore": {
              "description": "Restore a draw.io document without adding canvas history",
              "args": [
                {
                  "name": "session-id",
                  "index": 1,
                  "required": true
                },
                {
                  "name": "xml",
                  "index": 2,
                  "required": false
                },
                {
                  "name": "xml-file",
                  "takesValue": true,
                  "required": false
                },
                {
                  "name": "xml-stdin",
                  "takesValue": false,
                  "required": false
                },
                {
                  "name": "base-version",
                  "takesValue": true,
                  "required": false
                }
              ]
            }
          }
        }
      }
    }
  }
}
