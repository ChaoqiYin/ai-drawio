{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI Drawio",
  "mainBinaryName": "ai-drawio",
  "version": "0.1.0",
  "identifier": "com.example.ai-drawio",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:3001",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Drawio",
        "url": "index.html",
        "width": 1440,
        "height": 900,
        "visible": false,
        "resizable": true
      },
      {
        "label": "splash",
        "title": "AI Drawio \u6b63\u5728\u542f\u52a8",
        "url": "splash.html",
        "width": 420,
        "height": 280,
        "visible": false,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "../assets/ai-drawio.icns",
      "icons/icon.ico"
    ]
  }
}
