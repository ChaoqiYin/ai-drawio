{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI Drawio",
  "mainBinaryName": "ai-drawio",
  "version": "0.1.0",
  "identifier": "com.example.ai-drawio",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:3001",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Drawio",
        "url": "index.html",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "files": {
        "SharedSupport/cli-completions/_ai-drawio": "./target/cli-completions/_ai-drawio",
        "SharedSupport/cli-completions/ai-drawio.bash": "./target/cli-completions/ai-drawio.bash",
        "SharedSupport/cli-completions/ai-drawio.fish": "./target/cli-completions/ai-drawio.fish"
      }
    }
  },
  "plugins": {
    "cli": {
      "description": "AI Drawio packaged desktop command line interface",
      "subcommands": {
        "open": {
          "description": "Focus the desktop app window"
        },
        "status": {
          "description": "Inspect the running desktop shell state"
        },
        "conversation": {
          "description": "Manage local conversations",
          "subcommands": {
            "create": {
              "description": "Create a new local conversation"
            }
          }
        },
        "session": {
          "description": "Inspect or open local sessions",
          "subcommands": {
            "list": {
              "description": "List all local sessions"
            },
            "open": {
              "description": "Open a local session",
              "args": [
                {
                  "name": "session-id",
                  "index": 1,
                  "required": false
                },
                {
                  "name": "title",
                  "takesValue": true,
                  "required": false
                }
              ]
            }
          }
        },
        "canvas": {
          "description": "Read or write the current draw.io document",
          "subcommands": {
            "document.get": {
              "description": "Read the current draw.io document",
              "args": [
                {
                  "name": "session",
                  "takesValue": true,
                  "required": false
                },
                {
                  "name": "session-title",
                  "takesValue": true,
                  "required": false
                },
                {
                  "name": "output-file",
                  "takesValue": true,
                  "required": false
                }
              ]
            },
            "document.apply": {
              "description": "Apply a draw.io document to the resolved session",
              "args": [
                {
                  "name": "xml-file",
                  "index": 1,
                  "required": false
                },
                {
                  "name": "xml-stdin",
                  "takesValue": false,
                  "required": false
                },
                {
                  "name": "session",
                  "takesValue": true,
                  "required": false
                },
                {
                  "name": "session-title",
                  "takesValue": true,
                  "required": false
                },
                {
                  "name": "base-version",
                  "takesValue": true,
                  "required": false
                },
                {
                  "name": "prompt",
                  "takesValue": true,
                  "required": false
                },
                {
                  "name": "output-file",
                  "takesValue": true,
                  "required": false
                }
              ]
            }
          }
        }
      }
    }
  }
}
